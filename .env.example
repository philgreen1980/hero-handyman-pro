# Environment variables required to run this site outside of Manus.
# Copy this file to .env for local development, or enter these as
# "environment variables" / "secrets" in whatever hosting platform you use.

# --- Database (required) ---
# MySQL connection string, e.g: mysql://user:password@host:3306/dbname
DATABASE_URL=

# --- Session security (required) ---
# Any long random string - used to sign login session cookies.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# --- Admin login (required to use /admin/leads and /admin/estimator-leads) ---
# Pick a strong password - this is what you'll type in at /admin/login.
ADMIN_PASSWORD=

# --- Email notifications for new leads (recommended) ---
# Sign up free at https://resend.com, create an API key.
RESEND_API_KEY=
# The email address that should receive lead alerts.
OWNER_EMAIL=
# Optional - defaults to Resend's shared sandbox sender. Verify your own
# domain in Resend and set this once you're ready for better deliverability,
# e.g. leads@herohandymanpro.com
RESEND_FROM_EMAIL=

# --- Photo uploads (optional - contact/estimator forms work fine without it,
#     photos just won't attach) ---
# From an AWS IAM user with S3 read/write access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=



# --- Not needed anymore (legacy Manus-only settings, safe to leave blank) ---
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
